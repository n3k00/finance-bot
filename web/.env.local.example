# Public - exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY
NEXT_PUBLIC_SITE_URL=https://YOUR-APP.vercel.app

# Server-side only. Use the same value as the Supabase Edge Function
# WEBHOOK_SECRET secret if the function is configured to verify Telegram's
# x-telegram-bot-api-secret-token header.
WEBHOOK_SECRET=any-random-string-you-pick

# Server-side only. Required for /telegram Mini App allowlist auth.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY
TELEGRAM_MINI_APP_BOT_TOKEN=YOUR-TELEGRAM-BOT-TOKEN
